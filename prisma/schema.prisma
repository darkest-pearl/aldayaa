generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MenuCategory {
  id          String     @id @default(cuid())
  name        String
  description String?
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  items       MenuItem[]
}

model MenuItem {
  id          String       @id @default(cuid())
  name        String
  description String?
  price       Float
  isAvailable Boolean      @default(true)
  imageUrl    String?
  recommended Boolean      @default(false)
  isSignature Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id])
  orders      OrderItem[]

  @@index([isSignature])
}

model GalleryCategory {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  photos    Photo[]
}

model Photo {
  id          String          @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  categoryId  String
  category    GalleryCategory @relation(fields: [categoryId], references: [id])
}

model Reservation {
  id              String   @id @default(cuid())
  name            String
  phone           String
  email           String?
  date            DateTime
  time            String
  guests          Int      @default(1)
  specialRequests String?
  status          String   @default("PENDING")
  reference       String   @unique
  createdAt       DateTime @default(now())
}

model Order {
  id                  String           @id @default(cuid())
  name                String
  phone               String
  deliveryType        String
  address             String?
  notes               String?
  totalPrice          Float
  status              String           @default("NEW")
  createdAt           DateTime         @default(now())
  notifyWhenReady     Boolean          @default(false)
  paidOnline          Boolean          @default(false)
  reference           String           @unique
  tableId             String?
  tableLabel          String?
  tableSlug           String?
  orderContext        String           @default("STANDARD")
  createdByAdminId    String?
  createdByAdminEmail String?
  orderSource         String           @default("CUSTOMER")
  table               RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  items               OrderItem[]

  @@index([tableId])
  @@index([orderContext])
  @@index([createdByAdminId])
  @@index([orderSource])
}

model OrderItem {
  id         String    @id @default(cuid())
  orderId    String
  itemId     String?
  name       String
  price      Float
  quantity   Int
  menuItemId String?
  MenuItem   MenuItem? @relation(fields: [menuItemId], references: [id])
  order      Order     @relation(fields: [orderId], references: [id])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  role         String   @default("ADMIN")
}

model RestaurantSettings {
  id                    Int     @id @default(1)
  openingTime           String
  closingTime           String
  allowCancelPaid       Boolean @default(false)
  allowCancelInProgress Boolean @default(false)
  cancellationFee       Float   @default(0)
  workingHoursByDay     String?
  displayHours          String?
}

model RestaurantProfile {
  id                 Int      @id @default(1)
  restaurantName     String   @default("Al Dayaa Al Shamiah Restaurant")
  tagline            String   @default("Authentic Arabic & Indian flavors in the heart of Sharjah.")
  cuisineType        String   @default("Arabic & Indian")
  whatsappNumber     String   @default("+971 55 417 3293")
  whatsappLink       String   @default("https://wa.me/971554173293")
  address            String   @default("Al Dayaa Al Shamiah Restaurant")
  googleMapsUrl      String   @default("https://maps.app.goo.gl/n8Ced5MciXtpQCXCA")
  googleMapsEmbedUrl String   @default("https://www.google.com/maps?output=embed&q=Al%20Dayaa%20Al%20Shamiah%20Restaurant%20Sharjah")
  instagramUrl       String   @default("https://www.instagram.com/aldayaa.rest/?hl=en")
  facebookUrl        String   @default("https://www.facebook.com/aldayaaalshamiah/")
  tiktokUrl          String   @default("https://www.tiktok.com/@aldayaa_alshamiah")
  linktreeUrl        String   @default("https://linktr.ee/aldaya")
  logoUrl            String   @default("/images/logo-al-dayaa.png")
  primaryColor       String   @default("#d6b15f")
  secondaryColor     String   @default("#183b32")
  currency           String   @default("AED")
  enabledFeatures    String   @default("[\"WEBSITE\",\"MENU\",\"GALLERY\",\"RESERVATIONS\",\"ONLINE_ORDERING\",\"ANNOUNCEMENTS\",\"CONTACT_WHATSAPP\"]")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model RestaurantTable {
  id        String   @id @default(cuid())
  label     String
  slug      String   @unique
  qrToken   String   @unique
  seats     Int?
  zone      String?
  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]

  @@index([isActive])
  @@index([zone])
}

model InventoryItem {
  id           String              @id @default(cuid())
  name         String
  sku          String?             @unique
  category     String?
  unit         String
  currentStock Float               @default(0)
  reorderLevel Float?
  costPerUnit  Float?
  isActive     Boolean             @default(true)
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  movements    InventoryMovement[]

  @@index([name])
  @@index([category])
  @@index([isActive])
}

model InventoryMovement {
  id                  String        @id @default(cuid())
  itemId              String
  item                InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type                String
  quantity            Float
  reason              String?
  source              String?
  createdByAdminId    String?
  createdByAdminEmail String?
  createdAt           DateTime      @default(now())

  @@index([itemId])
  @@index([type])
  @@index([createdAt])
}

model Announcement {
  id        String   @id @default(cuid())
  message   String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
